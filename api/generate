export default async function handler(req, res) {
  try {
    const { keyword, anchor1, url1, anchor2, url2 } = req.body;

    // CALL GEMINI API (pseudo)
    const result = await generateWithGemini({
      keyword,
      anchor1,
      url1,
      anchor2,
      url2
    });

    return res.status(200).json({
      success: true,
      konten: result.html,
      seo: {
        judul: result.judul,
        judulSeo: result.judulSeo,
        slug: result.slug,
        meta: result.meta,
        kutipan: result.kutipan,
        tag: result.tag
      }
    });

  } catch (err) {
    return res.status(500).json({
      success: false,
      error: err.message
    });
  }
}
